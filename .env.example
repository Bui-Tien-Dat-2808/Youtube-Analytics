YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_KEYWORD_SOURCE=google_trends_rss
YOUTUBE_TRENDS_GEO=US
YOUTUBE_TOP_KEYWORDS_LIMIT=10
YOUTUBE_SEARCH_ORDER=viewCount
YOUTUBE_KEYWORD_FALLBACK=data engineering,machine learning,analytics engineering
YOUTUBE_SEARCH_KEYWORD=
YOUTUBE_CHANNEL_ID=
YOUTUBE_PAGE_SIZE=25
YOUTUBE_MAX_PAGES=4
YOUTUBE_LOOKBACK_DAYS=7

ICEBERG_CATALOG_NAME=local
ICEBERG_CATALOG_TYPE=hadoop
ICEBERG_NAMESPACE=youtube
ICEBERG_WAREHOUSE_PATH=file:///opt/project/data/warehouse
ICEBERG_RAW_TABLE=local.youtube.raw_videos
ICEBERG_CLEAN_TABLE=local.youtube.clean_videos

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=youtube_analytics
POSTGRES_USER=youtube
POSTGRES_PASSWORD=youtube
POSTGRES_SCHEMA=analytics

AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

DBT_PROJECT_DIR=/opt/project/dbt
DBT_PROFILES_DIR=/opt/project/dbt

SPARK_MASTER_URL=local[*]
SPARK_JARS_PACKAGES=org.apache.iceberg:iceberg-spark-runtime-3.5_2.12:1.5.2,org.postgresql:postgresql:42.7.4
LOCAL_STAGE_FILE_PATH=/opt/project/data/staging/youtube_raw_batch.jsonl
LOG_LEVEL=INFO

SUPERSET_SECRET_KEY=replace_with_a_secure_secret
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
